<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/bottom_navigation_height"
    android:background="@color/neutral_white_100">

    <ImageView
        android:id="@+id/icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/text"
        app:layout_constraintVertical_chainStyle="packed"
        app:tint="@color/neutral_black_100"
        android:src="@drawable/icon_1_line_community_24"
        tools:src="@drawable/icon_1_line_community_24" />

    <TextView
        android:id="@+id/text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginHorizontal="4dp"
        android:textSize="@dimen/bottom_navigation_textsize"
        android:textColor="@color/neutral_black_100"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="home"
        tools:text="home"
        tools:visibility="visible" />

    <!--    android:textSize="@dimen/caption1"-->

    <ImageView
        android:id="@+id/badge"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:src="@drawable/shape_badge_oval"
        app:layout_constraintTop_toTopOf="@+id/icon"
        app:layout_constraintStart_toEndOf="@+id/icon"
        app:layout_constraintEnd_toEndOf="@+id/icon"
        android:visibility="visible"
        tools:visibility="visible"
        />

</androidx.constraintlayout.widget.ConstraintLayout>