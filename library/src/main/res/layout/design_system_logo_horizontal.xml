<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_gravity="center_vertical">

    <ImageView
        android:id="@+id/logoIcon"
        android:layout_width="64.4dp"
        android:layout_height="26.1dp"
        android:layout_marginTop="3.1dp"
        android:layout_marginBottom="2.8dp"
        android:src="@drawable/logo_wanted_icon_item" />

    <ImageView
        android:id="@+id/logoText"
        android:layout_width="121.5dp"
        android:layout_height="26.8dp"
        android:layout_marginStart="9.4dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/logo_wanted_text_item" />

</LinearLayout>