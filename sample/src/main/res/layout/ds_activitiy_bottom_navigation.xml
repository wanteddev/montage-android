<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/semantic_base_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="1dp"
        app:title="Component > Bottom Navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <LinearLayout
        android:id="@+id/bottomNavigation1"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_navigation_height"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/home1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_home_24"
            app:icon_selected="@drawable/icon_2_fill_home_24"
            app:text="홈"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/search1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_search_24"
            app:icon_selected="@drawable/icon_2_fill_search_24"
            app:text="탐색"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/community1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_community_24"
            app:icon_selected="@drawable/icon_2_fill_community_24"
            app:text="커뮤니티"
            app:item_color="@color/neutral_black_100"
            app:show_badge="true" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/profile1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_mypage_24"
            app:icon_selected="@drawable/icon_2_fill_mypage_24"
            app:text="프로필"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/mywanted1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_profile_24"
            app:icon_selected="@drawable/icon_2_fill_profile_24"
            app:text="MY 원티드"
            app:item_color="@color/neutral_black_100"
            app:show_badge="true" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_navigation_height"
        android:layout_marginBottom="30dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation1">

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/home2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_home_24"
            app:icon_selected="@drawable/icon_2_fill_home_24"
            app:text="홈"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/search2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_search_24"
            app:icon_selected="@drawable/icon_2_fill_search_24"
            app:text="탐색"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/profile2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_mypage_24"
            app:icon_selected="@drawable/icon_2_fill_mypage_24"
            app:text="프로필"
            app:item_color="@color/neutral_black_100" />

        <com.wanted.android.designsystem.navigation.BottomNavigationItem
            android:id="@+id/mywanted2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?attr/selectableItemBackground"
            app:icon_normal="@drawable/icon_1_line_profile_24"
            app:icon_selected="@drawable/icon_2_fill_profile_24"
            app:text="MY 원티드"
            app:item_color="@color/neutral_black_100"
            app:show_badge="true" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>